            "QHeaderView::section": {
                "font_size": "12px",
                "font_weight": "bold",
                "color": "rgba(204, 204, 204, 0.02)",
                "background_color": "rgba(196, 15, 15, 0.61)",
                "border_bottom": "0px",
                "padding": "4px 8px"
            },
            "::item:selected": {
                "background_color": "#454eff"
            },
            "::branch": {
                "background_color": "rgba(193, 19, 19, 0)"
            }
        },
        "editor_tabs": {
            "_self": {
                "font_style": "italic",
                "background_color": "rgba(79, 193, 255, 0.02)",
                "padding": "0px"
            },
            "QWidget[selected=\"false\"]": {
                "font_size": "13px",
                "color": "#969696",
                "background_color": "rgba(45, 45, 45, 1)",
                "border": "none",
                "border_right": "1px solid #1e1e1e",
                "padding": "6px 16px"
            },
            "QWidget[selected=\"true\"]": {
                "color": "#ffffff",
                "background_color": "rgba(30, 30, 30, 0.02)"
            },
            "QWidget:hover[selected=\"false\"]": {
                "background_color": "#3c3c3c"
            },
            "#header_row": {
                "background_color": "rgba(133, 39, 39, 0.74)",
