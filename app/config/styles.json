{
    "global": {
        "_self": {
            "font_family": "Microsoft YaHei",
            "font_size": "18px",
            "color": "#cccccc"
        }
    },
    "types": {
        "Button": {
            "_self": {
                "font_weight": "bold",
                "color": "#ffffff",
                "background_color": "rgba(14, 99, 156, 0)",
                "border": "0px",
                "border_radius": "6px",
                "padding": "0px",
                "margin": "6px"
            },
            "&:hover": {
                "background_color": "rgba(153, 153, 153, 0.61)",
                "border": "0px"
            },
            "&:pressed": {
                "background_color": "rgba(153, 153, 153, 0.61)",
                "border": "1px solid #094771"
            }
        },
        "ComboBox": {
            "background_color": "#3c3c3c",
            "color": "#cccccc",
            "padding": "4px 8px",
            "border": "1px solid #3c3c3c"
        },
        "LineEdit": {
            "background_color": "#3c3c3c",
            "color": "#cccccc",
            "padding": "4px 8px",
            "border": "1px solid #3c3c3c"
        },
        "TextEdit": {
            "background_color": "#1e1e1e",
            "color": "#d4d4d4",
            "border": "none",
            "font_family": "Consolas, Microsoft YaHei",
            "font_size": "14px",
            "padding": "8px"
        },
        "SpinBox": {
            "background_color": "#3c3c3c",
            "color": "#cccccc",
            "padding": "2px 6px",
            "border": "1px solid #3c3c3c"
        },
        "DoubleSpinBox": {
            "background_color": "#3c3c3c",
            "color": "#cccccc",
            "padding": "2px 6px",
            "border": "1px solid #3c3c3c"
        },
        "CheckBox": {
            "color": "#cccccc",
            "background_color": "transparent"
        },
        "Label": {
            "font_weight": "normal",
            "color": "#cccccc",
            "background_color": "transparent"
        },
        "Slider": {
            "min_height": "24px",
            "background_color": "transparent"
        },
        "ProgressBar": {
            "min_height": "18px",
            "border_radius": "3px",
            "background_color": "#3c3c3c",
            "color": "#cccccc",
            "border": "1px solid #3c3c3c"
        },
        "GroupBox": {
            "color": "#cccccc",
            "font_weight": "bold",
            "border": "1px solid #3c3c3c",
            "padding": "12px 8px 8px 8px",
            "background_color": "transparent"
        },
        "TabWidget": {
            "_self": {
                "background_color": "#1e1e1e"
            }
        },
        "TreeView": {
            "_self": {
                "background_color": "#252526",
                "color": "#cccccc",
                "border": "none",
                "font_size": "13px"
            },
            "QHeaderView::section": {
                "background_color": "#252526",
                "color": "#cccccc",
                "border": "none",
                "border_bottom": "1px solid #3c3c3c",
                "padding": "4px 8px",
                "font_size": "12px",
                "font_weight": "bold"
            }
        },
        "ToolBar": {
            "background_color": "#323233",
            "border": "none",
            "padding": "2px 4px",
            "min_height": "36px"
        },
        "HSplitter": {
            "_self": {
                "background_color": "transparent"
            },
            "::handle:horizontal": {
                "background_color": "#3c3c3c",
                "width": "4px"
            }
        },
        "VSplitter": {
            "_self": {
                "background_color": "transparent"
            },
            "::handle:vertical": {
                "background_color": "#3c3c3c",
                "height": "4px"
            }
        }
    },
    "windows": {
        "main": {
            "_self": {
                "background_color": "#0c001e"
            }
        }
    },
    "widgets": {
        "ide_root": {
            "_self": {
                "background_color": "transparent"
            }
        },
        "title bar": {
            "_self": {
                "background_color": "rgba(0, 0, 0, 0)",
                "min_height": "40px"
            }
        },
        "ide_toolbar": {
            "_self": {
                "background_color": "rgba(50, 50, 51, 0.6)",
                "min_height": "36px",
                "padding": "0px 0px"
            },
            "QToolButton": {
                "font_size": "20px",
                "color": "#cccccc",
                "background_color": "transparent",
                "border": "none",
                "border_radius": "6px",
                "padding": "6px 14px",
                "margin": "0px 0px"
            },
            "QToolButton:hover": {
                "background_color": "#3c3c3c"
            },
            "QToolButton:pressed": {
                "background_color": "#505050"
            }
        },
        "main_vsplit": {
            "_self": {
                "background_color": "rgba(195, 55, 255, 0.02)"
