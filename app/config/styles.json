            "::handle:vertical": {
                "background_color": "rgba(251, 53, 53, 0)",
                "height": "3px"
            }
        },
        "work_hsplit": {
            "_self": {
                "background_color": "rgba(147, 125, 255, 0.02)"
            },
            "::handle:horizontal": {
                "background_color": "rgba(0, 191, 255, 0)",
                "width": "4px"
            }
        },
        "sidebar_panel": {
            "_self": {
                "background_color": "rgba(111, 39, 255, 0.02)",
                "min_width": "200px"
            }
        },
        "sidebar_header": {
            "_self": {
                "font_family": "Times New Roman",
                "font_size": "18px",
                "font_weight": "normal",
                "color": "#bababa",
                "background_color": "#586eff",
                "min_height": "0px",
                "padding": "4px 12px 4px 12px"
            }
        },
        "explorer_tree": {
            "_self": {
                "font_size": "13px",
                "font_weight": "bold",
                "color": "#cccccc",
                "background_color": "rgba(206, 248, 255, 0.41)"
